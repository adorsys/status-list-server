{
  "//": "markdownlint-cli2 configuration. Existing documentation in this repo uses long",
  "//": "lines (MD013) and code blocks. We disable a set of strict rules so the whole-repo",
  "//": "scan passes on legacy files while still catching genuine issues.",
  "config": {
    "default": true,
    "MD013": false,
    "MD041": false,
    "MD026": false,
    "MD022": false,
    "MD031": false,
    "MD032": false,
    "MD009": false,
    "MD012": {
      "maximum": 2
    }
  }
}
