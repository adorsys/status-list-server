# yamlfmt configuration
# https://github.com/google/yamlfmt

formatter:
  type: basic
  indent: 2
  line_ending: lf
  eof_newline: true

# Helm templates use Go template delimiters ({{ }}) that are not valid
# YAML for a formatter, so they are excluded from linting.
excludes:
  - "helm/**"
  - "node_modules/**"
  - "target/**"