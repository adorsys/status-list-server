#====================================================
# Application specific configuration
#====================================================
RUST_LOG=info
APP_ENV=development # development | production

APP_SERVER__HOST=0.0.0.0
APP_SERVER__DOMAIN=statuslist.example.com
APP_SERVER__PORT=8000
APP_SERVER__ENABLE_METRICS=false

# Certificate
APP_SERVER__CERT__EMAIL=support@example.com
APP_SERVER__CERT__ORGANIZATION=example.com
# (or https://acme-v02.api.letsencrypt.org/directory in production)
APP_SERVER__CERT__ACME_DIRECTORY_URL=https://pebble:14000/dir
# The last number is not explicitly defined in the spec
APP_SERVER__CERT__EKU=1,3,6,1,5,5,7,3,30
# Cron schedule for certificate renewal checks (6-field cron: sec min hour day month day-of-week)
# Must be a valid 6-field cron expression; invalid formats will cause startup to fail.
APP_SERVER__CERT__RENEWAL_CRON_SCHEDULE=0 0 0 * * *
# DNS challenge server URL used in development (Pebble challtestsrv)
APP_SERVER__CERT__DEVELOPMENT_DNS_CHALLENGE_URL=http://challtestsrv:8055
# DNS propagation timeout in seconds (Route53 change propagation in production)
APP_SERVER__CERT__DNS_PROPAGATION_TIMEOUT_SECS=300
# DNS propagation initial polling delay in seconds
APP_SERVER__CERT__DNS_PROPAGATION_INITIAL_DELAY_SECS=2
# Max retries when storing the signing key
APP_SERVER__CERT__SIGNING_KEY_MAX_RETRIES=3
# Retry delay in milliseconds between signing key storage attempts
APP_SERVER__CERT__SIGNING_KEY_RETRY_DELAY_MS=500

# Postgres connection string
APP_DATABASE__URL=postgres://postgres:postgres@db:5432/status-list

# Redis configuration
APP_REDIS__URI=redis://redis:6379
APP_REDIS__REQUIRE_CLIENT_AUTH=false
# TTL for the certificate cache in Redis. 
# Set to 0 to disable and always fetch from S3.
APP_REDIS__CERT_CACHE_TTL=3600
# Redis connection timeout in seconds
APP_REDIS__CONNECTION_TIMEOUT_SECS=60

# AWS SDK
APP_AWS__REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566 # remove this in production
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# TTL for the Secrets Manager cache. 
# Set to 0 to disable and always fetch from AWS API directly.
APP_AWS__SECRETS_CACHE_TTL=300
# Maximum number of secrets to cache in memory
APP_AWS__SECRETS_CACHE_MAX_CAPACITY=100
# S3 bucket name for storing certificate data
APP_AWS__S3_BUCKET=status-list-adorsys
# Optional prefix prepended to all S3 object keys (empty = no prefix)
APP_AWS__S3_KEY_PREFIX=
# Max retries for S3 bucket creation/existence checks
APP_AWS__S3_BUCKET_MAX_RETRIES=3
# Retry delay in milliseconds for S3 bucket operations
APP_AWS__S3_BUCKET_RETRY_DELAY_MS=500
# TTL (in seconds) for Route53 TXT records created during DNS-01 challenges
APP_AWS__ROUTE53_TXT_TTL=60

# Cache configuration
# TTL for the status list record cache. 
# Set to 0 to disable and always fetch from the database.
APP_CACHE__TTL=300
APP_CACHE__MAX_CAPACITY=1000

# Status list token configuration
# Token expiration in seconds (time from issuance until expiry)
APP_STATUS_LIST__TOKEN_EXP_SECS=900
# Token TTL in seconds (advertised lifetime of the status list token)
APP_STATUS_LIST__TOKEN_TTL_SECS=300

#====================================================
# Postgres configuration
#====================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=status-list